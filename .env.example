# Entity Core Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM Configuration (for extraction features)
# ===========================================

# API key for the LLM (required for extraction)
ENTITY_CORE_LLM_API_KEY=your_api_key_here

# API base URL (default: z.ai endpoint)
# ENTITY_CORE_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4/chat/completions

# Model to use (default: glm-4.7)
# ENTITY_CORE_LLM_MODEL=glm-4.7

# Temperature for sampling (0-2, lower = more deterministic)
# For extraction tasks, lower values (0.1-0.3) work best
# ENTITY_CORE_LLM_TEMPERATURE=0.3

# Maximum tokens in response (default: 2000)
# ENTITY_CORE_LLM_MAX_TOKENS=2000

# ===========================================
# Data Storage
# ===========================================

# Directory for storing entity-core data (identity, memories, graph)
# Default: ./data
# ENTITY_CORE_DATA_DIR=./data

# ===========================================
# Alternative: Use Psycheros env vars
# ===========================================
# Entity-core will fall back to these if ENTITY_CORE_* vars are not set:
# - ZAI_API_KEY
# - ZAI_BASE_URL
# - ZAI_MODEL
